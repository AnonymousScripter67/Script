--// STATUS UPDATE
local function updateStatus(p)
	if p <= 20 then
		status.Text = "Connecting to "..player.Name
	elseif p <= 50 then
		status.Text = "Loading trade system..."
	elseif p <= 70 then
		status.Text = "Loaded system modules"
	elseif p <= 90 then
		status.Text = "Finalizing scripts..."
	elseif p == 100 then
		status.Text = "Successfully Loaded Script"
	end
end

--// UPDATE FUNCTION
local function update(p)
	bar.Size = UDim2.new(p/100,0,1,0)
	percent.Text = p.."%"
	miniText.Text = p.."%"
	updateStatus(p)
end

--// HIDE SYSTEM
local function hideAll()
	bg.Visible = false
	mini.Visible = true
end

hideBtn.MouseButton1Click:Connect(hideAll)

--// LOADING SEQUENCE
for i = 1,20 do update(i) task.wait(0.1) end
for i = 21,50 do update(i) task.wait(0.2) end
for i = 51,70 do update(i) task.wait(0.2) end
for i = 71,90 do update(i) task.wait(0.2) end
for i = 91,99 do update(i) task.wait(0.3) end

update(99)
task.wait(2)

update(100)
task.wait(1)

--// CLEAN EXIT
local tween = TweenService:Create(
	overlay,
	TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
	{BackgroundTransparency = 1}
)
tween:Play()

task.wait(0.6)

if bgConn then bgConn:Disconnect() end
gui:Destroy()

--// RUN MAIN SCRIPT AFTER LOADER
task.spawn(onFinishedLoading)
